# =============================================
# 农药智能体 (Pesticide Agent) 环境变量配置
# =============================================
# 复制此文件为 .env 并填入实际值

# ============ LLM API 配置 (必需) ============
# 主模型 - OpenRouter API (推荐)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
LLM_MODEL_NAME=qwen/qwen3-32b

# 本地 VLLM 模式 (可选，用于本地部署)
VLLM_API_BASE=http://localhost:8000/v1
VLLM_MODEL_NAME=Qwen/Qwen2.5-32B-Instruct
# 设置为 'api' 或 'vllm' 来切换模式
LLM_MODE=api

# ============ Embedding API (BGE-M3) ============
# 设置为 'api' 或 'local' 来切换模式
EMBEDDING_MODE=api
# NVIDIA NIM API (推荐)
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_API_BASE=https://integrate.api.nvidia.com/v1
EMBEDDING_MODEL_NAME=baai/bge-m3
# 本地模型路径 (当 EMBEDDING_MODE=local 时使用)
EMBEDDING_MODEL_PATH=BAAI/bge-m3

# ============ Rerank API (BGE-Reranker) ============
RERANK_API_KEY=your_rerank_api_key_here
RERANK_API_BASE=https://api.siliconflow.cn/v1
RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3

# ============ DeepSeek OCR API ============
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.siliconflow.cn/v1
DEEPSEEK_MODEL_NAME=deepseek-ai/DeepSeek-OCR

# ============ 搜索功能 ============
# Serper API - Google 搜索
SERPER_KEY_ID=your_serper_api_key_here

# Tavily API (备用)
TAVILY_API_KEY=your_tavily_api_key_here

# ============ 网页抓取 ============
# Jina AI Reader API
JINA_API_KEYS=your_jina_api_key_here

# ============ 数据库配置 (Docker) ============
# 与 docker-compose.yml 保持一致
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5435
POSTGRES_USER=postgres
POSTGRES_PASSWORD=pesticide123
POSTGRES_DB=pesticide_db

# ============ 配方知识库元数据提取 LLM ============
# 用于从 Markdown 文件中提取元数据（剂型、有效成分、关键词等）
# 建议使用较便宜且快速的模型
RECIPE_KB_LLM_API_KEY=your_recipe_kb_llm_api_key_here
RECIPE_KB_LLM_API_BASE=https://openrouter.ai/api/v1
RECIPE_KB_LLM_MODEL_NAME=google/gemini-flash-1.5
# 元数据提取的温度参数（较低值更稳定）
RECIPE_KB_LLM_TEMPERATURE=0.1

# ============ 运行参数 ============
# 向量检索 Top-N
VECTOR_SEARCH_TOP_N=20
# Rerank 后 Top-K
RERANK_TOP_K=5

# ============ 配方知识库分块配置 ============
# 最大分块词数（约 1500-2000 中文字符）
RECIPE_KB_MAX_CHUNK_WORDS=800
# 最小分块词数（避免碎片块）
RECIPE_KB_MIN_CHUNK_WORDS=100
# 分块级别：h2 表示按二级标题切分
RECIPE_KB_SPLIT_LEVEL=h2
