# =============================================
# 农药智能体 (Pesticide Agent) 环境变量配置
# =============================================
# 复制此文件为 .env 并填入实际值

# ============ LLM API 配置 (必需) ============
# 主模型 - OpenRouter API (推荐)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
LLM_MODEL_NAME=qwen/qwen3-32b

# 测试模型 - CLI2API (可选) gpt-5.2
# OPENROUTER_API_KEY=your_cli2api_api_key_here
# OPENROUTER_API_BASE=http://127.0.0.1:8317/v1
# LLM_MODEL_NAME=gpt-5.2

# 本地 VLLM 模式 (可选，用于本地部署)
VLLM_API_BASE=http://localhost:8000/v1
VLLM_MODEL_NAME=Qwen/Qwen2.5-32B-Instruct

# 设置为 'api' 或 'vllm' 来切换模式
LLM_MODE=api

# ============ Embedding API (BGE-M3) ============
# 设置为 'api' 或 'local' 来切换模式
EMBEDDING_MODE=api

# SiliconFlow API (推荐)
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# 本地模型路径 (当 EMBEDDING_MODE=local 时使用)
# 1. 绝对/相对路径：直接指向已下载的模型文件夹
# 2. 模型 ID (需安装 modelscope)：如 "BAAI/bge-m3"，系统将自动下载
EMBEDDING_MODEL_PATH=BAAI/bge-m3

# ============ Rerank API (BGE-Reranker) ============
RERANK_API_KEY=your_rerank_api_key_here
RERANK_API_BASE=https://api.siliconflow.cn/v1
RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3

# ============ 搜索功能 ============
# Tavily API
# WEB_SEARCH_PROVIDER: 联网搜索 provider，仅在请求 enable_web_search=true 且本地知识不足时生效；可选 tavily / serper / hybrid
# WEB_SCRAPER_PROVIDER: 网页正文抓取 provider，仅在候选结果需要补正文时生效；可选 tavily / jina / hybrid
# WEB_SEARCH_MAX_RESULTS: 单次联网搜索最终保留的候选数量
# WEB_SEARCH_REQUIRE_FULLTEXT: true=抓不到正文就丢弃该来源；false=允许降级使用搜索摘要
# TAVILY_SEARCH_RETRIES: Tavily /search 失败时的重试次数
# TAVILY_SEARCH_DEPTH: Tavily /search 深度，advanced 更全面但更慢
# TAVILY_EXTRACT_DEPTH: Tavily /extract 深度，advanced 更完整但更慢
# WEB_SEARCH_INCLUDE_DOMAINS: 仅允许搜索这些域名，留空表示不限制
# WEB_SEARCH_PRIORITY_DOMAINS: 这些域名会被优先排序
# WEB_SEARCH_TRUSTED_DOMAINS: 命中后会标记为 trusted-domain
# WEB_SEARCH_EXCLUDE_DOMAINS: 排除这些域名
TAVILY_API_KEY=your_tavily_api_key_here
WEB_SEARCH_PROVIDER=tavily
WEB_SCRAPER_PROVIDER=tavily
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_REQUIRE_FULLTEXT=true
TAVILY_SEARCH_RETRIES=3
TAVILY_SEARCH_DEPTH=advanced
TAVILY_EXTRACT_DEPTH=advanced
WEB_SEARCH_INCLUDE_DOMAINS=
WEB_SEARCH_PRIORITY_DOMAINS=chinapesticide.org.cn,icama.cn,zzys.moa.gov.cn,ccpia.org.cn,bz.ccpia.org.cn
WEB_SEARCH_TRUSTED_DOMAINS=
WEB_SEARCH_EXCLUDE_DOMAINS=

# Serper API - Google 搜索
# SERPER_KEY_ID: 当 WEB_SEARCH_PROVIDER=serper / hybrid，或 Tavily 无结果回退时使用
SERPER_KEY_ID=your_serper_api_key_here

# ============ 网页抓取 ============
# Jina AI Reader API
JINA_API_KEYS=your_jina_api_key_here

# ============ 数据库配置 (Docker) ============
# 与 docker-compose.yml 保持一致
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5435
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=pesticide_db

# ============ 配方知识库元数据提取 LLM ============
# 用于从 Markdown 文件中提取元数据（剂型、有效成分、关键词等）
# 建议使用较便宜且快速的模型
RECIPE_KB_LLM_API_KEY=your_recipe_kb_llm_api_key_here
RECIPE_KB_LLM_API_BASE=https://openrouter.ai/api/v1
RECIPE_KB_LLM_MODEL_NAME=google/gemini-flash-1.5
# 元数据提取的温度参数（较低值更稳定）
RECIPE_KB_LLM_TEMPERATURE=0.1

# ============ 运行参数 ============
# 向量检索 Top-N
VECTOR_SEARCH_TOP_N=20
# 最终返回数量（Rerank 成功或降级到向量结果时都使用）
RETRIEVAL_FINAL_TOP_K=5

# ============ 配方知识库分块配置 ============
# 最大分块词数（约 1500-2000 中文字符）
RECIPE_KB_MAX_CHUNK_WORDS=800
# 最小分块词数（避免碎片块）
RECIPE_KB_MIN_CHUNK_WORDS=100
